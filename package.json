{
  "name": "gto-preflop-trainer",
  "version": "1.0.0",
  "private": true,
  "description": "Single-file pre-flop poker GTO decision trainer (see gto-trainer.html)",
  "scripts": {
    "test": "node --test \"test/*.test.js\"",
    "test:update": "node test/update-snapshot.js",
    "test:solver": "python tools/solver/run_all.py",
    "test:ui": "node test/ui-smoke.js",
    "test:all": "node --test \"test/*.test.js\" && node test/ui-smoke.js && python tools/solver/run_all.py",
    "build:www": "node tools/build-www.js",
    "app:sync": "node tools/build-www.js && cap copy",
    "app:android": "node tools/build-www.js && cap copy android && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@revenuecat/purchases-capacitor": "^13.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0"
  }
}
